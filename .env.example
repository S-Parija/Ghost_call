# GhostCall configuration
# FastAPI Cloud and Render set PORT automatically. Locally, main.py defaults to 8000.
PORT=8000

# Optional WebRTC ICE server override as JSON.
# Use this for production TURN servers if users need reliable NAT traversal.
ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302","stun:stun1.l.google.com:19302"]}]

# Optional Web Push configuration for incoming-call push notifications.
# Generate keys with:
# uv run vapid --gen
# uv run vapid --applicationServerKey --private-key private_key.pem
VAPID_PRIVATE_KEY=private_key.pem
VAPID_PRIVATE_KEY_B64=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com
